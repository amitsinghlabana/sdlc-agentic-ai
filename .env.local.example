# ─────────────────────────────────────────────────────────────────────────────
#  SECRETS-ONLY overrides.  COPY this file to ".env.local" and put REAL values in.
#
#  Why this exists:
#    • .env.local is gitignored AND should NEVER be attached to an AI chat.
#    • config.py loads it AFTER .env with override=True, so values here win.
#    • Keep .env free of secrets (leave those lines blank there) — that way the
#      file you do share/attach (.env) never contains a token or key.
#
#  Rule of thumb: .env = structure & non-secret config (shareable);
#                 .env.local = secrets (private).
# ─────────────────────────────────────────────────────────────────────────────

# JIRA — paste a freshly ROTATED token (not an old/shared one):
JIRA_API_TOKEN=

# Azure OpenAI — paste KEY 1 from the Azure portal "Keys and Endpoint" page:
AZURE_OPENAI_API_KEY=

# Vanilla OpenAI (only if LLM_PROVIDER=openai):
OPENAI_API_KEY=

# Foundry IQ (only if KNOWLEDGE_PROVIDER=foundry) — Azure AI Search admin/query key:
FOUNDRY_API_KEY=

# GitHub (only if GITHUB_PROVIDER=cloud) — fine-grained PAT scoped to your sandbox repo:
GITHUB_TOKEN=



