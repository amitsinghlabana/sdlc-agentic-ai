# ── LLM provider selection ───────────────────────────────────────────────────
# mock   = free, offline, deterministic (DEFAULT — great for local testing/demos)
# azure  = Azure OpenAI (set the AZURE_* vars below)
# openai = vanilla OpenAI (set OPENAI_API_KEY)
LLM_PROVIDER=mock

# ── Azure OpenAI (only needed when LLM_PROVIDER=azure) ───────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# This is the *deployment* name you created in Azure AI Foundry, e.g. gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Vanilla OpenAI (only needed when LLM_PROVIDER=openai) ────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── LLM TLS (corporate HTTPS inspection — same fix as the JIRA_* ones) ───────
# Default verifies via the OS/Windows trust store. If Azure/OpenAI calls fail with
# SSL CERTIFICATE_VERIFY_FAILED: set LLM_CA_BUNDLE to your corporate root CA (.pem),
# or (last resort, INSECURE) set LLM_VERIFY_SSL=false.
LLM_CA_BUNDLE=
LLM_VERIFY_SSL=true

# ── Generation tuning (cost guardrails) ──────────────────────────────────────
# General output cap for text agents (requirements/architect/reviewer/docs).
LLM_MAX_TOKENS=3000
# Larger cap for code-emitting agents (developer/tester). A multi-file response
# is big; too small a cap truncates the JSON and the files are lost. Raise this
# if generated code looks cut off.
LLM_CODE_MAX_TOKENS=8000
LLM_TEMPERATURE=0.4
LLM_TIMEOUT=90

# ── Orchestration ────────────────────────────────────────────────────────────
MAX_REVIEW_LOOPS=2
# Cosmetic delay between streamed text chunks (seconds). 0 = fastest.
STREAM_DELAY=0.015

# ── JIRA integration ─────────────────────────────────────────────────────────
# mock  = free, offline, in-memory (DEFAULT — demo keys like DEMO-101, no account)
# cloud = real JIRA Cloud (set the JIRA_* vars below)
JIRA_PROVIDER=mock

# Only needed when JIRA_PROVIDER=cloud:
JIRA_BASE_URL=https://YOUR-SITE.atlassian.net
JIRA_EMAIL=you@example.com
# Create at id.atlassian.com -> Security -> API tokens
JIRA_API_TOKEN=
# A sandbox project key to create issues in (e.g. SDLC)
JIRA_PROJECT_KEY=MAV
# Optional: instance-specific custom field id for story points (leave blank to skip)
JIRA_STORY_POINTS_FIELD=
# Default assignee for created stories/sub-tasks. Options:
#   (blank) = leave unassigned | me = the API-token owner | <email> | <accountId>
JIRA_DEFAULT_ASSIGNEE=
# Sub-task issue type name (company-managed JIRA uses "Sub-task"; some use "Subtask")
JIRA_SUBTASK_ISSUE_TYPE=Sub-task
# When true, the cloud client logs what it WOULD create without writing to JIRA
JIRA_DRY_RUN=false
# TLS for corporate networks doing HTTPS inspection (fixes SSL CERTIFICATE_VERIFY_FAILED).
# Default verifies via the OS/Windows trust store (truststore). If it still fails:
#   - point at your corporate root CA:  JIRA_CA_BUNDLE=C:\path\to\corp-root-ca.pem
#   - or (last resort, INSECURE):        JIRA_VERIFY_SSL=false
JIRA_CA_BUNDLE=
JIRA_VERIFY_SSL=true

# ── Knowledge / grounding (Microsoft Foundry IQ) ─────────────────────────────
# mock    = free, offline grounding from docs/standards/*.md (DEFAULT)
# foundry = real Foundry IQ agentic retrieval (Azure AI Search knowledge agent)
KNOWLEDGE_PROVIDER=mock
# How many grounded sources to inject per run.
KNOWLEDGE_TOP_K=4
# Local corpus the mock grounds against (defaults to <repo>/docs/standards).
KNOWLEDGE_DIR=

# Only needed when KNOWLEDGE_PROVIDER=foundry:
FOUNDRY_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
FOUNDRY_KNOWLEDGE_AGENT=sdlc-knowledge-agent
FOUNDRY_INDEX=sdlc-standards
FOUNDRY_API_VERSION=2025-08-01-preview
# FOUNDRY_API_KEY goes in .env.local (secret), not here.
# TLS reuse for the knowledge endpoint (same as LLM_*/JIRA_*):
KNOWLEDGE_CA_BUNDLE=
KNOWLEDGE_VERIFY_SSL=true

# ── GitHub integration ───────────────────────────────────────────────────────
# mock  = free, offline (DEFAULT — simulates branch+PR / new-repo, no account)
# cloud = real GitHub REST API (set GITHUB_OWNER below + GITHUB_TOKEN in .env.local)
GITHUB_PROVIDER=mock
# The account/org that owns repos (e.g. your GitHub username). Required for cloud
# unless GITHUB_REPO includes the owner.
GITHUB_OWNER=your-github-username
# Default repo — FLEXIBLE:
#   "owner/name" → work on that repo (existing → branch + PR)
#   "name" only  → that repo under GITHUB_OWNER
#   empty        → no default repo; the agent CREATES a new one (named from the feature)
# The commit message + PR text are authored by the LLM.
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main
GITHUB_PRIVATE=true
GITHUB_DRY_RUN=false
GITHUB_API_URL=https://api.github.com
# GITHUB_TOKEN (fine-grained PAT) goes in .env.local (secret), not here.
GITHUB_CA_BUNDLE=
GITHUB_VERIFY_SSL=true


